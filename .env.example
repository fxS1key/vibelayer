# Server
PORT=8080
NODE_ENV=development
DATABASE_URL=postgres://vibelayer:vibelayer@localhost:5432/vibelayer
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-me-with-a-long-random-string
CORS_ORIGINS=chrome-extension://*,http://localhost:5173

# LLM providers (only the one you use must be set; gateway picks dynamically)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEFAULT_LLM_MODEL=claude-sonnet-4-6

# Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_TOPUP_SMALL=
STRIPE_PRICE_TOPUP_LARGE=

# Rate limits (requests / minute / user)
RATE_LIMIT_GENERATE=20
RATE_LIMIT_SYNC=120

# Token markup multiplier over provider cost (3.0 = 3x)
TOKEN_MARKUP=3.0
