{
  "manifest_version": 3,
  "name": "VibeLayer",
  "version": "0.2.0",
  "description": "Personalize any website by describing changes in natural language.",
  "action": {
    "default_title": "Open VibeLayer",
    "default_popup": "src/popup/index.html",
    "default_icon": { "16": "icons/16.png", "48": "icons/48.png", "128": "icons/128.png" }
  },
  "side_panel": { "default_path": "src/panel/index.html" },
  "background": { "service_worker": "src/background.ts", "type": "module" },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content.ts"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "storage", "sidePanel", "scripting", "commands"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "icons": { "16": "icons/16.png", "48": "icons/48.png", "128": "icons/128.png" },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+V", "mac": "Command+Shift+V" },
      "description": "Open VibeLayer popup"
    },
    "open-side-panel": {
      "suggested_key": { "default": "Ctrl+Shift+L", "mac": "Command+Shift+L" },
      "description": "Open VibeLayer side panel"
    }
  }
}
